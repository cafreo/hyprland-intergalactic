# DEPENDENCIES: git

# PULL CHANGES FROM REMOTE, WHEN IN GIT DIRECTORY

cmd "箚뒧  git pull" %{{
    git pull 
}}

cmd "箚뒧  git push" %{{
    git push 
}}

cmd "箚뒧  git push new version for aur package" %{{
    printf " 箚뜣  commit message: "
    read -r ans
    git add PKGBUILD .SRCINFO
    git commit -m "$ans"
    git push
}}

# KEYMAPS

map pgd "箚뒧  git pull"
map pgu "箚뒧  git push"
